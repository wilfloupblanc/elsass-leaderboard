{
  "name": "elsass-leaderboard-display",
  "private": true,
  "version": "1.0.0",
  "main": "src/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"cross-env BROWSER=none vite --port 5174\" \"wait-on http://localhost:5174 && electron .\"",
    "build": "vite build && electron-builder",
    "build:win": "vite build && electron-builder --win",
    "preview": "vite preview"
  },
  "dependencies": {
    "concurrently": "^10.0.1",
    "cross-env": "^10.1.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sass": "^1.100.0",
    "wait-on": "^9.0.10",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12",
    "electron": "42.3.0",
    "electron-builder": "26.8.1"
  },
  "build": {
    "appId": "fr.elsass-simracing.leaderboard-display",
    "productName": "Elsass Leaderboard Display",
    "directories": { "output": "dist-electron" },
    "files": [
      "dist/**/*",
      "src/main/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icons/win/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "npmRebuild": false
  }
}
